# Database
POSTGRES_USER=foodflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=foodflow
POSTGRES_HOST_PORT=5432
# Keep this port aligned with POSTGRES_HOST_PORT for host-run backend commands.
DATABASE_URL=postgresql://foodflow:change_me_in_production@localhost:5432/foodflow

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-secret-change-me-64-chars-minimum-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-64-chars-minimum-xxxxxxxxxxxxxxxx

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=foodflow
MINIO_PUBLIC_URL=http://localhost:9000

# N8N
N8N_ENCRYPTION_KEY=change-me-64-char-hex-string-00000000000000000000000000000000
N8N_API_KEY=dev-n8n-api-key-64-chars-minimum-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
N8N_WEBHOOK_URL=http://n8n:5678/webhook

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SePay
# Runtime requires SEPAY_API_KEY and SEPAY_ACCOUNT_NUMBER to create payment intents.
# Webhooks require SEPAY_WEBHOOK_SECRET and reject unsigned requests.
SEPAY_API_KEY=your-sepay-api-key
SEPAY_ACCOUNT_NUMBER=your-sepay-account-number
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret

# AI Chat
# Direct chatbot runtime uses DeepSeek when DEEPSEEK_API_KEY is configured.
# Store production keys only in secret managers or ignored local .env files.
AI_CHAT_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_MAX_OUTPUT_TOKENS=600
DEEPSEEK_TIMEOUT_MS=15000
DEEPSEEK_DAILY_BUDGET_USD=0

# Legacy N8N/Gemini workflows can still use Gemini credentials.
GEMINI_API_KEY=your-gemini-api-key

# App
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081,http://localhost:8082
