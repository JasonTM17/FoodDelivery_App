# Database
POSTGRES_USER=foodflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=foodflow
POSTGRES_HOST_PORT=5432
# Keep this port aligned with POSTGRES_HOST_PORT for host-run backend commands.
DATABASE_URL=postgresql://foodflow:change_me_in_production@localhost:5432/foodflow
DIRECT_URL=postgresql://foodflow:change_me_in_production@localhost:5432/foodflow
# Supabase production:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
# DIRECT_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Production providers
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=minio
QUEUE_PROVIDER=bullmq
# Used only when QUEUE_PROVIDER=supabase-postgres (for example, Railway worker).
JOB_OUTBOX_POLL_INTERVAL_MS=1000
JOB_OUTBOX_DRAIN_LIMIT=25
# Required in production when QUEUE_PROVIDER=supabase-postgres.
# Store the real value only in Vercel/Supabase secret managers.
CRON_SECRET=your-cron-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_REALTIME_JWT_PRIVATE_KEY=your-es256-private-key
SUPABASE_REALTIME_JWT_KEY_ID=your-supabase-signing-key-id
SUPABASE_STORAGE_BUCKET=foodflow-public
SUPABASE_KYC_BUCKET=foodflow-private

# Pricing
DELIVERY_BASE_FEE_VND=15000

# JWT
JWT_SECRET=dev-secret-change-me-64-chars-minimum-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-64-chars-minimum-xxxxxxxxxxxxxxxx

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=foodflow
MINIO_KYC_BUCKET=foodflow-kyc
MINIO_PUBLIC_URL=http://localhost:9000
STORAGE_MAX_UPLOAD_MB=5
DRIVER_KYC_MAX_UPLOAD_MB=4
DRIVER_KYC_RETRY_LIMIT=3
THROTTLER_MEMORY_FALLBACK=false

# Maps/routing
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Production must use an owned OSRM/route service; local/test may use the public OSRM demo.
OSRM_URL=https://router.project-osrm.org
WEBHOOK_SECRET=your-webhook-secret

# SePay
# VietQR intents require the beneficiary account and official bank short name/code.
# Webhooks require a rotated HMAC secret and reject stale or unsigned requests.
SEPAY_API_KEY=your-sepay-api-key
SEPAY_ACCOUNT_NUMBER=0000000000
SEPAY_BANK_NAME=Vietcombank
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret-at-least-32-characters

# AI Chat
# Direct chatbot runtime uses DeepSeek when DEEPSEEK_API_KEY is configured.
# Store production keys only in secret managers or ignored local .env files.
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_EMBEDDING_MODEL=text-embedding-v3
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high

# RAG Knowledge Base
RAG_ENABLED=true
RAG_TOP_K=3
RAG_MIN_SIMILARITY=0.70
RAG_SYNC_INTERVAL_MS=300000
RAG_SYNC_BATCH_SIZE=100
RAG_SYNC_CONCURRENCY=4

DEEPSEEK_MAX_OUTPUT_TOKENS=600
DEEPSEEK_TIMEOUT_MS=15000
DEEPSEEK_DAILY_BUDGET_USD=0

# Email delivery (BullMQ SMTP worker)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@foodflow.vn

# Push/SMS notification delivery
# FCM uses Firebase Admin SDK (HTTP v1). Keep the service-account JSON in a
# secret manager; local/managed environments may use ADC instead.
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_JSON=
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=your-twilio-from-number

# App
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081,http://localhost:8082
