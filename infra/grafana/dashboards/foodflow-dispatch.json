{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"},
    {"name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki"}
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "title": "FoodFlow Dispatch",
  "uid": "foodflow-dispatch",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Dispatch Attempts / min",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(dispatch_attempts_total[1m]) * 60", "instant": true, "legendFormat": "Attempts/min"}]
    },
    {
      "id": 2, "type": "stat", "title": "Dispatch Success Rate",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.8}, {"color": "green", "value": 0.9}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "1 - (rate(dispatch_no_driver_total[5m]) / rate(dispatch_attempts_total[5m]))", "instant": true, "legendFormat": "Success Rate"}]
    },
    {
      "id": 3, "type": "stat", "title": "No-Driver Rate",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.05}, {"color": "red", "value": 0.1}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(dispatch_no_driver_total[5m]) / rate(dispatch_attempts_total[5m])", "instant": true, "legendFormat": "No-Driver Rate"}]
    },
    {
      "id": 4, "type": "stat", "title": "Avg Assignment Time",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 30}, {"color": "red", "value": 60}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(dispatch_assignment_duration_seconds_sum[5m]) / rate(dispatch_assignment_duration_seconds_count[5m])", "instant": true, "legendFormat": "Avg Time"}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Dispatch Attempts vs Success",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(dispatch_attempts_total[1m]) * 60", "legendFormat": "Attempts/min"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(dispatch_no_driver_total[1m]) * 60", "legendFormat": "No-Driver/min"}
      ]
    },
    {
      "id": 6, "type": "logs", "title": "Dispatch Error Logs",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 7},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "options": {"dedupStrategy": "none", "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true},
      "targets": [{"datasource": {"type": "loki", "uid": "${DS_LOKI}"}, "expr": "{job=\"backend\"} |= \"dispatch\" |= \"error\" | json", "legendFormat": ""}]
    }
  ]
}
