# Self-hosted Docker compatibility profile. Supabase + Vercel production uses
# provider-managed environment variables documented in docs/deployment.md.
# Copy to .env.production (never commit real secrets)
# docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d
#
# Production backend fail-closed validation requires ALL keys below.
# Do not use local defaults: minioadmin, localhost JWT, router.project-osrm.org, etc.
# See backend/src/config/env.validation.ts (productionRequiredKeys).

IMAGE_TAG=v4.0.0

# --- Infrastructure (compose services) ---
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=minio
QUEUE_PROVIDER=bullmq
POSTGRES_PASSWORD=replace-with-strong-password
REDIS_PASSWORD=replace-with-strong-password
MINIO_ROOT_USER=foodflowminio
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_ACCESS_KEY=foodflowminio
MINIO_SECRET_KEY=replace-with-strong-minio-password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_PUBLIC_URL=https://storage.example.com
MINIO_BUCKET=foodflow
MINIO_KYC_BUCKET=foodflow-kyc
DRIVER_KYC_MAX_UPLOAD_MB=4
DRIVER_KYC_RETRY_LIMIT=3

DATABASE_URL=postgresql://foodflow:replace-with-strong-password@postgres:5432/foodflow
DIRECT_URL=postgresql://foodflow:replace-with-strong-password@postgres:5432/foodflow
REDIS_URL=redis://:replace-with-strong-password@redis:6379

# JWT: min 64 chars in production
JWT_SECRET=replace-with-64-plus-char-random-string-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace-with-another-64-plus-char-random-string-xxxxxxxxxxxx

DELIVERY_BASE_FEE_VND=15000
CORS_ORIGINS=https://replace-with-admin-alias.vercel.app,https://replace-with-restaurant-alias.vercel.app
PASSWORD_RESET_URL_BASE=https://replace-with-admin-alias.vercel.app/reset-password
THROTTLER_MEMORY_FALLBACK=false
AUTH_PUBLIC_THROTTLE_LIMIT=100

# --- Required integrations (examples only; production requires real rotated values) ---
GOOGLE_MAPS_API_KEY=replace-with-google-maps-key
OSRM_URL=https://osrm.example.com
DEEPSEEK_API_KEY=replace-with-deepseek-key
SEPAY_API_KEY=replace-with-sepay-key
SEPAY_ACCOUNT_NUMBER=0123456789
SEPAY_WEBHOOK_SECRET=replace-with-sepay-webhook-secret
WEBHOOK_SECRET=replace-with-generic-webhook-secret
SMTP_HOST=smtp.example-mail.com
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass
SMTP_FROM=noreply@foodflow.vn
FCM_SERVER_KEY=replace-with-fcm-server-key
TWILIO_ACCOUNT_SID=replace-with-twilio-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-token
TWILIO_FROM_NUMBER=+84900000000
