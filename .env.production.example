# Copy to .env.production (never commit real secrets)
# docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d

IMAGE_TAG=latest

POSTGRES_PASSWORD=replace-with-strong-password
REDIS_PASSWORD=replace-with-strong-password
MINIO_ROOT_PASSWORD=replace-with-strong-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-with-strong-password
MINIO_PUBLIC_URL=https://storage.example.com
MINIO_BUCKET=foodflow

DATABASE_URL=postgresql://foodflow:replace-with-strong-password@postgres:5432/foodflow
DIRECT_URL=postgresql://foodflow:replace-with-strong-password@postgres:5432/foodflow
REDIS_URL=redis://:replace-with-strong-password@redis:6379

# min 32 chars; production validation forbids localhost defaults
JWT_SECRET=replace-with-64-plus-char-random-string-xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace-with-another-64-plus-char-random-string-xxxx

DELIVERY_BASE_FEE_VND=15000
CORS_ORIGINS=https://admin.foodflow.vn,https://restaurant.foodflow.vn
PASSWORD_RESET_URL_BASE=https://admin.foodflow.vn/reset-password

# Optional integrations
GOOGLE_MAPS_API_KEY=
SEPAY_API_KEY=
SEPAY_ACCOUNT_NUMBER=
SEPAY_WEBHOOK_SECRET=
DEEPSEEK_API_KEY=
