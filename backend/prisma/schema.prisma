generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── Enums ───

enum UserRole {
  customer
  driver
  restaurant
  admin
}

enum OrderStatus {
  created
  pending_payment
  paid
  restaurant_pending
  restaurant_accepted
  preparing
  ready_for_pickup
  driver_assigned
  driver_arriving_restaurant
  picked_up
  delivering
  delivered
  completed
  cancelled
  refunded
}

enum PaymentMethod {
  cash
  wallet
  sepay
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum VehicleType {
  motorbike
  car
  bicycle
}

enum PriceRange {
  low    @map("$")
  medium @map("$$")
  high   @map("$$$")
}

enum DeliveryTaskStatus {
  assigned
  heading_to_restaurant
  at_restaurant
  picked_up
  heading_to_customer
  delivered
}

enum TicketIssueType {
  late_delivery
  wrong_item
  missing_item
  driver_issue
  refund_request
  other
}

enum TicketStatus {
  open
  in_progress
  waiting_customer
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  critical
}

enum ChatSenderType {
  customer
  driver
  restaurant
  admin
  ai
  system
}

enum AiUsageOutcome {
  succeeded
  failed
}

enum ChatSessionType {
  ai_support
  driver_customer
  restaurant_driver
}

enum PromotionType {
  percentage
  fixed
  free_delivery
  bogo
  combo
}

enum RestaurantApprovalStatus {
  pending
  approved
  changes_requested
  rejected
  suspended
}

enum StaffRole {
  owner
  manager
  kitchen
  cashier
  viewer
}

enum StaffInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum StaffShiftStatus {
  scheduled
  completed
  cancelled
}

enum PromotionStatus {
  draft
  scheduled
  active
  paused
  expired
  archived
}

enum SupportChannel {
  ai_chat
  email
  phone
  in_app
}

enum SupportMessageType {
  public_reply
  internal_note
  system
}

enum ExportJobStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum ExportFormat {
  csv
  xlsx
  parquet
}

enum KycStatus {
  pending
  approved
  rejected
}

enum LocaleCode {
  vi
  en
  ja
}

// ─── Models ───

model User {
  id               String     @id @default(uuid()) @db.Uuid
  email            String     @unique @db.VarChar(255)
  phone            String?    @unique @db.VarChar(20)
  passwordHash     String     @map("password_hash") @db.VarChar(255)
  fullName         String     @map("full_name") @db.VarChar(100)
  role             UserRole   @default(customer)
  avatarUrl        String?    @map("avatar_url") @db.VarChar(500)
  isActive         Boolean    @default(true) @map("is_active")
  failedLoginCount Int        @default(0) @map("failed_login_count")
  lockedUntil      DateTime?  @map("locked_until") @db.Timestamptz()
  preferredLocale  LocaleCode @default(vi) @map("preferred_locale")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  customerProfile         CustomerProfile?
  driverProfile           DriverProfile?
  restaurantProfile       RestaurantProfile?
  addresses               Address[]
  reviews                 Review[]                 @relation("ReviewCustomer")
  driverReviews           Review[]                 @relation("ReviewDriver")
  notifications           Notification[]
  loyaltyTransactions     LoyaltyTransaction[]
  walletTransactions      WalletTransaction[]
  referralCode            ReferralCode?
  referralAsReferrer      ReferralRedemption[]     @relation("Referrer")
  referralAsInvitee       ReferralRedemption[]     @relation("Invitee")
  chatSessions            ChatSession[]
  ordersAsCustomer        Order[]                  @relation("CustomerOrders")
  ordersAsDriver          Order[]                  @relation("DriverOrders")
  deliveryTasks           DeliveryTask[]
  driverLocationHistory   DriverLocationHistory[]
  supportTickets          AiSupportTicket[]
  assignedSupportTickets  AiSupportTicket[]        @relation("SupportAssignee")
  supportMessages         SupportTicketMessage[]
  auditLogs               AdminAuditLog[]
  requestedExports        AdminExportJob[]
  updatedPlatformSettings PlatformSetting[]
  createdStaffInvites     StaffInvite[]            @relation("StaffInviteCreator")
  reviewedKycSubmissions  DriverKycSubmission[]    @relation("KycReviewer")
  driverBankAccounts      DriverBankAccount[]
  driverTipReports        DriverTipReport[]
  promotionUsages         PromotionUsage[]
  cart                    Cart?
  notificationSettings    NotificationSetting[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  fcmTokens               UserFcmToken[]
  aiUsageEvents           AiUsageEvent[]
  dispatchOffers          DispatchOffer[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model CustomerProfile {
  id                  String  @id @default(uuid()) @db.Uuid
  userId              String  @unique @map("user_id") @db.Uuid
  defaultAddressId    String? @map("default_address_id") @db.Uuid
  savedPaymentMethods Json?   @map("saved_payment_methods") @db.JsonB
  preferences         Json?   @db.JsonB
  totalOrders         Int     @default(0) @map("total_orders")

  user           User     @relation(fields: [userId], references: [id])
  defaultAddress Address? @relation("DefaultAddress", fields: [defaultAddressId], references: [id])

  @@map("customer_profiles")
}

model DriverProfile {
  id                  String      @id @default(uuid()) @db.Uuid
  userId              String      @unique @map("user_id") @db.Uuid
  licenseNumber       String?     @map("license_number") @db.VarChar(50)
  vehicleType         VehicleType @default(motorbike) @map("vehicle_type")
  vehiclePlate        String?     @map("vehicle_plate") @db.VarChar(20)
  isOnline            Boolean     @default(false) @map("is_online")
  isVerified          Boolean     @default(false) @map("is_verified")
  currentLat          Float?      @map("current_lat")
  currentLng          Float?      @map("current_lng")
  rating              Decimal     @default(5.0) @db.Decimal(2, 1)
  totalDeliveries     Int         @default(0) @map("total_deliveries")
  totalEarnings       Decimal     @default(0) @map("total_earnings") @db.Decimal(12, 0)
  maxDeliveryRadiusKm Int         @default(5) @map("max_delivery_radius_km")
  termsAcceptedAt     DateTime?   @map("terms_accepted_at") @db.Timestamptz()
  termsVersion        String?     @map("terms_version") @db.VarChar(32)

  user           User                  @relation(fields: [userId], references: [id])
  kycSubmissions DriverKycSubmission[]

  @@map("driver_profiles")
}

model DriverBankAccount {
  id                String   @id @default(uuid()) @db.Uuid
  driverId          String   @map("driver_id") @db.Uuid
  bankCode          String   @map("bank_code") @db.VarChar(32)
  bankName          String   @map("bank_name") @db.VarChar(160)
  accountNumber     String   @map("account_number") @db.VarChar(64)
  accountHolderName String   @map("account_holder_name") @db.VarChar(160)
  isDefault         Boolean  @default(false) @map("is_default")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  driver User @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, bankCode, accountNumber])
  @@index([driverId, isDefault])
  @@map("driver_bank_accounts")
}

model RestaurantProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @map("user_id") @db.Uuid
  restaurantId          String    @map("restaurant_id") @db.Uuid
  staffRole             StaffRole @default(owner) @map("staff_role")
  permissions           Json      @default("[]") @db.JsonB
  isActive              Boolean   @default(true) @map("is_active")
  joinedAt              DateTime  @default(now()) @map("joined_at") @db.Timestamptz()
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz()

  user       User         @relation(fields: [userId], references: [id])
  restaurant Restaurant   @relation(fields: [restaurantId], references: [id])
  shifts     StaffShift[]

  @@index([restaurantId, staffRole, isActive])
  @@map("restaurant_profiles")
}

model Restaurant {
  id                 String                                @id @default(uuid()) @db.Uuid
  name               String                                @db.VarChar(200)
  slug               String                                @unique @db.VarChar(200)
  description        String?                               @db.Text
  logoUrl            String?                               @map("logo_url") @db.VarChar(500)
  coverUrl           String?                               @map("cover_url") @db.VarChar(500)
  location           Unsupported("geography(Point, 4326)")
  addressLine        String                                @map("address_line") @db.VarChar(300)
  city               String                                @db.VarChar(100)
  district           String?                               @db.VarChar(100)
  phone              String?                               @db.VarChar(20)
  cuisineTypes       String[]                              @map("cuisine_types")
  priceRange         PriceRange                            @default(medium) @map("price_range")
  rating             Decimal                               @default(5.0) @db.Decimal(2, 1)
  totalReviews       Int                                   @default(0) @map("total_reviews")
  isOpen             Boolean                               @default(true) @map("is_open")
  isActive           Boolean                               @default(true) @map("is_active")
  approvalStatus     RestaurantApprovalStatus              @default(pending) @map("approval_status")
  approvalNotes      String?                               @map("approval_notes") @db.Text
  approvedAt         DateTime?                             @map("approved_at") @db.Timestamptz()
  approvedById       String?                               @map("approved_by_id") @db.Uuid
  onboardingState    Json?                                 @map("onboarding_state") @db.JsonB
  prepTimeAvgMinutes Int                                   @default(15) @map("prep_time_avg_minutes")
  minOrderAmount     Decimal                               @default(0) @map("min_order_amount") @db.Decimal(10, 0)
  createdAt          DateTime                              @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime                              @updatedAt @map("updated_at") @db.Timestamptz()

  profiles        RestaurantProfile[]
  openingHours    RestaurantOpeningHour[]
  holidayClosures RestaurantHolidayClosure[]
  categories      Category[]
  menuItems       MenuItem[]
  orders          Order[]
  reviews         Review[]
  promotions      Promotion[]
  staffInvites    StaffInvite[]
  staffShifts     StaffShift[]

  @@index([city])
  @@index([approvalStatus, createdAt(sort: Desc)])
  @@map("restaurants")
}

model RestaurantOpeningHour {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @map("restaurant_id") @db.Uuid
  dayOfWeek    Int     @map("day_of_week") @db.SmallInt
  openTime     String  @map("open_time") @db.VarChar(5)
  closeTime    String  @map("close_time") @db.VarChar(5)
  isClosed     Boolean @default(false) @map("is_closed")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@map("restaurant_opening_hours")
}

model RestaurantHolidayClosure {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  date         DateTime @db.Date
  reason       String?  @db.VarChar(200)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date], map: "restaurant_holiday_closures_restaurant_date_key")
  @@index([restaurantId, date], map: "restaurant_holiday_closures_restaurant_date_idx")
  @@map("restaurant_holiday_closures")
}

model StaffInvite {
  id           String            @id @default(uuid()) @db.Uuid
  restaurantId String            @map("restaurant_id") @db.Uuid
  email        String            @db.VarChar(255)
  role         StaffRole
  permissions  Json              @default("[]") @db.JsonB
  tokenHash    String            @unique @map("token_hash") @db.VarChar(128)
  status       StaffInviteStatus @default(pending)
  invitedById  String            @map("invited_by_id") @db.Uuid
  expiresAt    DateTime          @map("expires_at") @db.Timestamptz()
  acceptedAt   DateTime?         @map("accepted_at") @db.Timestamptz()
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  invitedBy  User       @relation("StaffInviteCreator", fields: [invitedById], references: [id])

  @@index([restaurantId, status, createdAt(sort: Desc)])
  @@index([email, status])
  @@map("staff_invites")
}

model StaffShift {
  id                  String           @id @default(uuid()) @db.Uuid
  restaurantId        String           @map("restaurant_id") @db.Uuid
  restaurantProfileId String           @map("restaurant_profile_id") @db.Uuid
  startsAt            DateTime         @map("starts_at") @db.Timestamptz()
  endsAt              DateTime         @map("ends_at") @db.Timestamptz()
  status              StaffShiftStatus @default(scheduled)
  note                String?          @db.VarChar(300)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  restaurant Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  profile    RestaurantProfile @relation(fields: [restaurantProfileId], references: [id], onDelete: Cascade)

  @@index([restaurantId, startsAt, endsAt])
  @@index([restaurantProfileId, startsAt])
  @@map("staff_shifts")
}

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  parentId     String?  @map("parent_id") @db.Uuid
  name         String   @db.VarChar(100)
  icon         String?  @db.VarChar(50)
  isVisible    Boolean  @default(true) @map("is_visible")
  sortOrder    Int      @default(0) @map("sort_order")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  parent         Category?       @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]      @relation("CategoryTree")
  menuItems      MenuItem[]
  promotionItems PromotionItem[]

  @@index([restaurantId, parentId, sortOrder])
  @@map("categories")
}

model MenuItem {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  name         String   @db.VarChar(200)
  description  String?  @db.Text
  imageUrl     String?  @map("image_url") @db.VarChar(500)
  basePrice    Decimal  @map("base_price") @db.Decimal(10, 0)
  isAvailable  Boolean  @default(true) @map("is_available")
  isPopular    Boolean  @default(false) @map("is_popular")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  category       Category         @relation(fields: [categoryId], references: [id])
  options        MenuItemOption[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  promotionItems PromotionItem[]

  @@index([restaurantId, categoryId, sortOrder])
  @@index([categoryId])
  @@map("menu_items")
}

model MenuItemOption {
  id         String   @id @default(uuid()) @db.Uuid
  menuItemId String   @map("menu_item_id") @db.Uuid
  name       String   @db.VarChar(100)
  isRequired Boolean  @default(false) @map("is_required")
  isMultiple Boolean  @default(false) @map("is_multiple")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  menuItem MenuItem              @relation(fields: [menuItemId], references: [id])
  values   MenuItemOptionValue[]

  @@map("menu_item_options")
}

model MenuItemOptionValue {
  id            String  @id @default(uuid()) @db.Uuid
  optionId      String  @map("option_id") @db.Uuid
  value         String  @db.VarChar(100)
  priceModifier Decimal @default(0) @map("price_modifier") @db.Decimal(10, 0)

  option MenuItemOption @relation(fields: [optionId], references: [id])

  @@map("menu_item_option_values")
}

model Cart {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  restaurantId  String?  @map("restaurant_id") @db.Uuid
  promotionCode String?  @map("promotion_code") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id              String  @id @default(uuid()) @db.Uuid
  cartId          String  @map("cart_id") @db.Uuid
  menuItemId      String  @map("menu_item_id") @db.Uuid
  quantity        Int     @default(1)
  selectedOptions Json    @default("[]") @map("selected_options") @db.JsonB
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 0)
  notes           String? @db.VarChar(300)

  cart     Cart     @relation(fields: [cartId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("cart_items")
}

model Order {
  id                           String        @id @default(uuid()) @db.Uuid
  orderCode                    String        @unique @map("order_code") @db.VarChar(12)
  customerId                   String        @map("customer_id") @db.Uuid
  restaurantId                 String        @map("restaurant_id") @db.Uuid
  driverId                     String?       @map("driver_id") @db.Uuid
  deliveryAddressId            String        @map("delivery_address_id") @db.Uuid
  status                       OrderStatus   @default(created)
  subtotal                     Decimal       @db.Decimal(10, 0)
  deliveryFee                  Decimal       @map("delivery_fee") @db.Decimal(10, 0)
  promotionDiscount            Decimal       @default(0) @map("promotion_discount") @db.Decimal(10, 0)
  total                        Decimal       @db.Decimal(10, 0)
  paymentMethod                PaymentMethod @map("payment_method")
  notes                        String?       @db.Text
  estimatedPrepTimeMinutes     Int?          @map("estimated_prep_time_minutes")
  estimatedDeliveryTimeMinutes Int?          @map("estimated_delivery_time_minutes")
  actualDeliveryTimeMinutes    Int?          @map("actual_delivery_time_minutes")
  cancelledReason              String?       @map("cancelled_reason") @db.Text
  commissionRateAtOrderTime    Decimal       @default(15.0) @map("commission_rate_at_order_time") @db.Decimal(4, 2)
  routePolyline                String?       @map("route_polyline") @db.Text
  routeWaypoints               Json?         @map("route_waypoints") @db.JsonB
  createdAt                    DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                    DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  customer               User                    @relation("CustomerOrders", fields: [customerId], references: [id])
  restaurant             Restaurant              @relation(fields: [restaurantId], references: [id])
  driver                 User?                   @relation("DriverOrders", fields: [driverId], references: [id])
  deliveryAddress        Address                 @relation(fields: [deliveryAddressId], references: [id])
  orderItems             OrderItem[]
  statusHistory          OrderStatusHistory[]
  payment                Payment?
  paymentIntent          PaymentIntent?
  paymentWebhookReceipts PaymentWebhookReceipt[]
  refundRequests         PaymentRefundRequest[]
  payoutLedgers          PayoutLedger[]
  deliveryTask           DeliveryTask?
  driverTipReports       DriverTipReport[]
  reviews                Review[]
  supportTickets         AiSupportTicket[]
  promotionUsages        PromotionUsage[]
  chatSessions           ChatSession[]
  dispatchOffers         DispatchOffer[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([restaurantId, status])
  @@index([driverId, status])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  orderId         String  @map("order_id") @db.Uuid
  menuItemId      String  @map("menu_item_id") @db.Uuid
  nameSnapshot    String  @map("name_snapshot") @db.VarChar(200)
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 0)
  selectedOptions Json    @default("[]") @map("selected_options") @db.JsonB
  notes           String? @db.VarChar(300)

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  status    String   @db.VarChar(30)
  changedBy String   @map("changed_by") @db.VarChar(50)
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  order          Order                  @relation(fields: [orderId], references: [id])
  refundRequests PaymentRefundRequest[]

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  orderId       String        @unique @map("order_id") @db.Uuid
  amount        Decimal       @db.Decimal(10, 0)
  method        PaymentMethod
  status        PaymentStatus @default(pending)
  transactionId String        @map("transaction_id") @db.VarChar(100)
  paidAt        DateTime?     @map("paid_at") @db.Timestamptz()
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  order                 Order                  @relation(fields: [orderId], references: [id])
  paymentRefundRequests PaymentRefundRequest[]

  @@map("payments")
}

model DeliveryTask {
  id                 String                                @id @default(uuid()) @db.Uuid
  orderId            String                                @unique @map("order_id") @db.Uuid
  driverId           String                                @map("driver_id") @db.Uuid
  pickupLocation     Unsupported("geography(Point, 4326)")
  dropoffLocation    Unsupported("geography(Point, 4326)")
  status             DeliveryTaskStatus                    @default(assigned)
  pickupDistanceKm   Decimal?                              @map("pickup_distance_km") @db.Decimal(5, 2)
  deliveryDistanceKm Decimal?                              @map("delivery_distance_km") @db.Decimal(5, 2)
  driverRating       Decimal?                              @map("driver_rating") @db.Decimal(2, 1)
  assignedAt         DateTime                              @default(now()) @map("assigned_at") @db.Timestamptz()
  pickedUpAt         DateTime?                             @map("picked_up_at") @db.Timestamptz()
  deliveredAt        DateTime?                             @map("delivered_at") @db.Timestamptz()
  routeGeojson       Json?                                 @map("route_geojson") @db.JsonB
  durationInTraffic  Int?                                  @map("duration_in_traffic")

  order  Order @relation(fields: [orderId], references: [id])
  driver User  @relation(fields: [driverId], references: [id])

  @@map("delivery_tasks")
}

model DriverIncentiveCampaign {
  id           String   @id @default(uuid()) @db.Uuid
  title        String   @db.VarChar(150)
  rewardAmount Int      @map("reward_amount")
  targetOrders Int      @map("target_orders")
  startsAt     DateTime @map("starts_at") @db.Timestamptz()
  endsAt       DateTime @map("ends_at") @db.Timestamptz()
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([isActive, startsAt, endsAt])
  @@map("driver_incentive_campaigns")
}

model DriverLocationHistory {
  id         BigInt                                @id @default(autoincrement()) @db.BigInt
  driverId   String                                @map("driver_id") @db.Uuid
  location   Unsupported("geography(Point, 4326)")
  orderId    String?                               @map("order_id") @db.Uuid
