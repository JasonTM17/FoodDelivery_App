  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver User  @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([orderId, driverId])
  @@index([driverId, createdAt(sort: Desc)])
  @@map("driver_tip_reports")
}

enum LoyaltyTxnType {
  credit
  debit
}

model LoyaltyTransaction {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        LoyaltyTxnType @default(credit)
  description String         @default("")
  orderId     String?        @map("order_id") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("loyalty_transactions")
}

enum WalletTxnType {
  credit
  debit
}

model WalletTransaction {
  id              String                @id @default(uuid()) @db.Uuid
  userId          String                @map("user_id") @db.Uuid
  refundRequestId String?               @unique @map("refund_request_id") @db.Uuid
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  refundRequest   PaymentRefundRequest? @relation(fields: [refundRequestId], references: [id], onDelete: SetNull)
  amountDelta     Int                   @map("amount_delta")
  type            WalletTxnType
  reason          String
  refId           String?               @map("ref_id") @db.Uuid
  status          String                @default("CONFIRMED") @db.VarChar(20)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, refId, reason])
  @@map("wallet_transactions")
}

model ReferralCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([code])
  @@map("referral_codes")
}

model ReferralRedemption {
  id             String   @id @default(uuid()) @db.Uuid
  referrerUserId String   @map("referrer_user_id") @db.Uuid
  inviteeUserId  String   @map("invitee_user_id") @db.Uuid
  referrer       User     @relation("Referrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  invitee        User     @relation("Invitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  rewardAmount   Int      @default(0) @map("reward_amount")
  redeemedAt     DateTime @default(now()) @map("redeemed_at") @db.Timestamptz(6)

  @@unique([referrerUserId, inviteeUserId])
  @@index([referrerUserId])
  @@index([inviteeUserId])
  @@map("referral_redemptions")
}

model IdempotencyRequest {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  idempotencyKey String   @map("idempotency_key") @db.VarChar(64)
  statusCode     Int      @map("status_code")
  responseBody   Json     @map("response_body") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@index([createdAt])
  @@map("idempotency_requests")
}

// ─── RAG Knowledge Base ───

model RagDocument {
  id        String   @id @default(uuid()) @db.Uuid
  docType   String   @map("doc_type") @db.VarChar(50)
  locale    String   @default("vi") @db.VarChar(10)
  title     String   @db.VarChar(300)
  content   String   @db.Text
  sourceId  String?  @map("source_id") @db.VarChar(100)
  contentHash String? @map("content_hash") @db.Char(64)
  embedding Unsupported("vector(1536)")?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([docType, locale])
  @@map("rag_documents")
}
