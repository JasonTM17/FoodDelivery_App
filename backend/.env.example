# Database
DATABASE_URL=postgresql://foodflow:foodflow_dev@localhost:5432/foodflow
DIRECT_URL=postgresql://foodflow:foodflow_dev@localhost:5432/foodflow
# Supabase production:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Production providers
# Local development keeps Socket.IO + MinIO + BullMQ. Production uses Supabase
# for database/realtime/storage and Vercel for the API/web surfaces.
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=minio
QUEUE_PROVIDER=bullmq
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_STORAGE_BUCKET=foodflow-production

# Pricing
DELIVERY_BASE_FEE_VND=15000

# JWT
# Production requires 64+ chars; generate with: openssl rand -hex 64
JWT_SECRET=replace-with-64-plus-char-random-string
JWT_REFRESH_SECRET=replace-with-another-64-plus-char-random-string
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=foodflow
MINIO_PUBLIC_URL=http://localhost:9000
STORAGE_MAX_UPLOAD_MB=5
THROTTLER_MEMORY_FALLBACK=false

# External APIs
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Production must use an owned OSRM/route service; local/test default to the public OSRM demo.
OSRM_URL=https://router.project-osrm.org
WEBHOOK_SECRET=your-webhook-secret

# Email delivery (BullMQ SMTP worker)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@foodflow.vn

# Push/SMS notification delivery
FCM_SERVER_KEY=your-fcm-server-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=your-twilio-from-number

# SePay
SEPAY_API_KEY=your-sepay-api-key
SEPAY_ACCOUNT_NUMBER=your-sepay-account-number
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret

# AI Chat
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_MAX_OUTPUT_TOKENS=600
DEEPSEEK_TIMEOUT_MS=15000
DEEPSEEK_DAILY_BUDGET_USD=0

# App
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003
