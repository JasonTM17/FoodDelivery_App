# Database
DATABASE_URL=postgresql://foodflow:foodflow_dev@localhost:5432/foodflow
DIRECT_URL=postgresql://foodflow:foodflow_dev@localhost:5432/foodflow
# Supabase production:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
# DIRECT_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Production providers
# Local development keeps Socket.IO + MinIO + BullMQ. Production uses Supabase
# for database/realtime/storage, Railway for API/worker/Redis, and Vercel for
# the web dashboards.
REALTIME_PROVIDER=socketio
STORAGE_PROVIDER=minio
QUEUE_PROVIDER=bullmq
# Required in production: `api` for the HTTP service, `worker` for the worker.
FOODFLOW_PROCESS_ROLE=api
# Used only when QUEUE_PROVIDER=supabase-postgres (for example, Railway worker).
JOB_OUTBOX_POLL_INTERVAL_MS=1000
JOB_OUTBOX_DRAIN_LIMIT=25
# Required in production when QUEUE_PROVIDER=supabase-postgres.
# Store the real value only in Railway/Supabase secret managers.
CRON_SECRET=your-cron-secret
SUPABASE_URL=https://your-project.supabase.co
# Opaque backend key for Supabase APIs that support the new key format.
SUPABASE_SECRET_KEY=your-supabase-secret-key
# Legacy JWT scoped to server-side Storage authorization. Never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_REALTIME_JWT_PRIVATE_KEY=your-es256-private-key
SUPABASE_REALTIME_JWT_KEY_ID=your-supabase-signing-key-id
SUPABASE_STORAGE_BUCKET=foodflow-public
SUPABASE_KYC_BUCKET=foodflow-private

# Pricing
DELIVERY_BASE_FEE_VND=15000

# JWT
# Production requires 64+ chars; generate with: openssl rand -hex 64
JWT_SECRET=replace-with-64-plus-char-random-string
JWT_REFRESH_SECRET=replace-with-another-64-plus-char-random-string
# Ed25519 cutover (Phase 2+): base64 DER SPKI public + PKCS8 private.
# Generate: pnpm exec ts-node scripts/generate-ed25519-keypair.ts
# JWT_ED25519_PUBLIC_KEY=
# JWT_ED25519_PRIVATE_KEY=
# Dual-verify HS256 while draining in-flight tokens (set false after Phase 3)
LEGACY_HS256_FALLBACK=true
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=foodflow
MINIO_KYC_BUCKET=foodflow-kyc
MINIO_PUBLIC_URL=http://localhost:9000
STORAGE_MAX_UPLOAD_MB=5
DRIVER_KYC_MAX_UPLOAD_MB=4
DRIVER_KYC_RETRY_LIMIT=3
THROTTLER_MEMORY_FALLBACK=false

# External APIs
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Production must use an owned OSRM/route service; local/test default to the public OSRM demo.
OSRM_URL=https://router.project-osrm.org
WEBHOOK_SECRET=your-webhook-secret

# Email delivery (BullMQ SMTP worker)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@foodflow.vn

# Push/SMS notification delivery
# FCM uses Firebase Admin SDK (HTTP v1). Supply the service-account JSON only
# through a secret manager, or leave it blank to use ADC/workload identity.
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_JSON=
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=your-twilio-from-number

# SePay
SEPAY_API_KEY=your-sepay-api-key
SEPAY_ACCOUNT_NUMBER=your-sepay-account-number
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret

# AI Chat
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_EMBEDDING_MODEL=text-embedding-v3
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_MAX_OUTPUT_TOKENS=600
DEEPSEEK_TIMEOUT_MS=15000
DEEPSEEK_DAILY_BUDGET_USD=0

# RAG indexes only live restaurant/menu rows; it never inserts demo fixtures.
RAG_ENABLED=true
RAG_TOP_K=3
RAG_MIN_SIMILARITY=0.70
RAG_SYNC_INTERVAL_MS=300000
RAG_SYNC_BATCH_SIZE=100
RAG_SYNC_CONCURRENCY=4

# App
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003
