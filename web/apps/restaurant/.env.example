NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_RESTAURANT_URL=http://localhost:3002
NEXT_PUBLIC_REALTIME_PROVIDER=socketio
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# No API key or billing account is required for the OpenFreeMap basemap.
NEXT_PUBLIC_MAP_PROVIDER=openfreemap
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Optional local-only proxy for legacy relative /api calls during next dev.
# Do not enable this in production or Vercel.
FOODFLOW_ENABLE_DEV_API_REWRITE=false
