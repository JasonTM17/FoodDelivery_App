NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000
NEXT_PUBLIC_REALTIME_PROVIDER=socketio
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required only for the live driver map.
# This key is public by design; restrict it by HTTP referrer in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-browser-key
