{
  "name": "foodflow-web",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm --config.verify-deps-before-run=false -r --if-present --workspace-concurrency=1 run build",
    "start": "turbo start",
    "lint": "pnpm --config.verify-deps-before-run=false -r --if-present --workspace-concurrency=1 run lint",
    "typecheck": "pnpm --config.verify-deps-before-run=false -r --if-present --workspace-concurrency=1 run typecheck",
    "test": "pnpm --config.verify-deps-before-run=false -r --if-present --workspace-concurrency=1 run test",
    "ui:add": "cd packages/ui && npx shadcn@latest add",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:install": "playwright install chromium firefox"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint-config-prettier": "^9.1.0",
    "turbo": "^2.6.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.0.0"
}
