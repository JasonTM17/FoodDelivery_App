    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "turbo": "^2.6.0",
    "typescript": "^6.0.3",
    "@playwright/test": "^1.49.0"
  },
  "packageManager": "pnpm@10.0.0"
}
