{
  "name": "foodflow-web",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "ui:add": "cd packages/ui && npx shadcn@latest add",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
